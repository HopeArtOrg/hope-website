---
import { HeroSection } from "@/components/landing/hero-section";
import { IntroductionSection } from "@/components/landing/introduction";
import { getLangFromUrl, getLocalePath, useTranslations } from "@/i18n/utils";
import BaseLayout from "@/layouts/base-layout.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout>
  <HeroSection
    description={t("hero.description")}
    downloadLabel={t("hero.download")}
    downloadForLabel={t("hero.downloadFor")}
    githubLabel={t("hero.github")}
    comingSoonLabel={t("hero.comingSoon")}
    client:load
  />
  <IntroductionSection
    heading={t("intro.heading")}
    description1={t("intro.description1")}
    description2={t("intro.description2")}
    ctaLabel={t("intro.cta")}
    ctaHref={getLocalePath(lang, "/blogs")}
    appScreenshotAlt={t("intro.appScreenshot")}
    repoScreenshotAlt={t("intro.repoScreenshot")}
    client:visible
  />
</BaseLayout>
