---
import { AboutSection } from "@/components/landing/about";
import { DemoSection } from "@/components/landing/demo";
import { HeroSection } from "@/components/landing/hero-section";
import { TechAnimationSection } from "@/components/landing/tech-animation";
import { getLangFromUrl, getLocalePath, useTranslations } from "@/i18n/utils";
import BaseLayout from "@/layouts/base-layout.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout>
  <HeroSection
    description={t("hero.description")}
    downloadLabel={t("hero.download")}
    downloadForLabel={t("hero.downloadFor")}
    githubLabel={t("hero.github")}
    comingSoonLabel={t("hero.comingSoon")}
    client:load
  />
  <AboutSection
    heading={t("about.heading")}
    description1={t("about.description1")}
    description2={t("about.description2")}
    ctaLabel={t("about.cta")}
    ctaHref={getLocalePath(lang, "/blogs")}
    appScreenshotAlt={t("about.appScreenshot")}
    repoScreenshotAlt={t("about.repoScreenshot")}
    client:visible
  />
  <TechAnimationSection
    label={t("techAnimation.label")}
    client:visible
  />
  <DemoSection
    heading={t("demo.heading")}
    description={t("demo.description")}
    courtesy={t("demo.courtesy")}
    client:visible
  />
</BaseLayout>
